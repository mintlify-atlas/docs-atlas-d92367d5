  "keyFeatures": [
    "Add, edit, and delete expense entries with amount, category, date, and description",
    "Set per-category monthly budget limits with visual progress bars",
    "Interactive doughnut chart for category spending distribution",
    "Bar chart comparing budget limits vs actual spending",
    "Dashboard stats showing total expenses, transaction count, and average expense",
    "SQLite-backed persistent storage via a Flask REST API",
    "Seven built-in expense categories: Food, Transport, Shopping, Entertainment, Bills, Health, Other"
  ],
  "publicApiSurface": [
    "GET /api/expenses",
    "POST /api/expenses",
    "PUT /api/expenses/<expense_id>",
    "DELETE /api/expenses/<expense_id>",
    "GET /api/budgets",
    "POST /api/budgets",
    "GET /api/stats"
  ]
